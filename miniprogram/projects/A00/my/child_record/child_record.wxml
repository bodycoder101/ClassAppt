<view wx:if="{{!isLoad}}" class="margin-top load loading text-l load-project"></view>

<view wx:if="{{isLoad}}" class="main padding-project child-record">
	<view wx:if="{{child}}" class="profile card-project shadow-project">
		<view class="name">{{child.CHILD_NAME}}</view>
		<view class="meta text-grey">
			<text wx:if="{{child.CHILD_SEX}}">{{child.CHILD_SEX}}</text>
			<text wx:if="{{child.CHILD_BIRTHDAY}}"> / {{child.CHILD_BIRTHDAY}}</text>
			<text wx:if="{{child.CHILD_CLASS}}"> / {{child.CHILD_CLASS}}</text>
		</view>
		<view wx:if="{{child.CHILD_MEMO}}" class="memo text-grey">{{child.CHILD_MEMO}}</view>
	</view>

	<view class="section-title">预约记录</view>
	<view wx:if="{{!joinList.length}}" class="load notexist text-grey">暂无预约记录</view>
	<view class="record card-project shadow-project" wx:for="{{joinList}}" wx:key="_id">
		<view bindtap="url" data-url="../join_detail/my_join_detail?id={{item._id}}">
			<view class="record-title content-cut-two">{{item.JOIN_MEET_TITLE}}</view>
			<view class="record-time text-grey">{{item.JOIN_MEET_DAY_DESC}} {{item.JOIN_MEET_TIME_START}}～{{item.JOIN_MEET_TIME_END}}</view>
			<view class="record-status">
				<text wx:if="{{item.JOIN_STATUS==0}}" class="text-orange">待审核</text>
				<text wx:elif="{{item.JOIN_STATUS==1}}" class="text-green">预约成功{{item.JOIN_IS_CHECKIN==1?'，已签到':''}}</text>
				<text wx:elif="{{item.JOIN_STATUS==8}}" class="text-orange">审核未通过</text>
				<text wx:elif="{{item.JOIN_STATUS==10}}" class="text-grey">已取消</text>
				<text wx:elif="{{item.JOIN_STATUS==99}}" class="text-orange">系统取消</text>
				<text class="text-grey margin-left-s">{{item.JOIN_ADD_TIME}}</text>
			</view>
			<view wx:if="{{item.JOIN_REASON}}" class="text-grey content-cut-two">备注：{{item.JOIN_REASON}}</view>
		</view>
	</view>

	<view class="section-title margin-top-l">请假记录</view>
	<view wx:if="{{!leaveList.length}}" class="load notexist text-grey">暂无请假记录</view>
	<view class="record card-project shadow-project" wx:for="{{leaveList}}" wx:key="_id">
		<view class="record-title content-cut-two">{{item.LEAVE_MEET_TITLE}}</view>
		<view class="record-time text-grey">{{item.LEAVE_MEET_DAY_DESC}} {{item.LEAVE_MEET_TIME_START}}～{{item.LEAVE_MEET_TIME_END}}</view>
		<view class="record-status">
			<text wx:if="{{item.LEAVE_STATUS==0}}" class="text-orange">待审核</text>
			<text wx:elif="{{item.LEAVE_STATUS==1}}" class="text-green">已通过</text>
			<text wx:elif="{{item.LEAVE_STATUS==8}}" class="text-orange">已拒绝</text>
			<text wx:elif="{{item.LEAVE_STATUS==10}}" class="text-grey">已取消</text>
			<text class="text-grey margin-left-s">{{item.LEAVE_ADD_TIME}}</text>
		</view>
		<view wx:if="{{item.LEAVE_REASON}}" class="text-grey content-cut-two">原因：{{item.LEAVE_REASON}}</view>
		<view wx:if="{{item.LEAVE_ADMIN_REASON}}" class="text-grey content-cut-two">处理备注：{{item.LEAVE_ADMIN_REASON}}</view>
	</view>
</view>
